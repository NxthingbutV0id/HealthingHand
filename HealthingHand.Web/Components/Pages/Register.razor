@page "/register"
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav

<PageTitle>Register</PageTitle>

<h3>Create Account</h3>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

<form method="post" action="/auth/register">
    <input type="hidden" name="ReturnUrl" value="/" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" type="email" name="Email" required />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Display Name</label>
            <input class="form-control" type="text" name="DisplayName" required />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Password</label>
            <input class="form-control" type="password" name="Password" minlength="8" required />
            <div class="form-text">Must be at least 8 characters.</div>
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">Age</label>
            <input class="form-control" type="number" name="Age" min="1" max="120" required />
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">Sex</label>
            <select class="form-select" name="Sex">
                <option value="Undefined">Prefer not to say</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </select>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Height (m)</label>
            <input class="form-control" type="number" step="0.01" min="0.01" name="HeightM" required />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Weight (kg)</label>
            <input class="form-control" type="number" step="0.1" min="0.1" name="WeightKg" required />
        </div>
    </div>

    <button class="btn btn-primary" type="submit">Register</button>
</form>

@code {
    private string? ErrorMessage;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var error))
            ErrorMessage = Uri.UnescapeDataString(error.ToString());
    }
}