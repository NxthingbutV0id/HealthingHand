@page "/user"
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using HealthingHand.Data.Entries
@using HealthingHand.Web.Services
@using HealthingHand.Web.Services.WeightItems
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav
@inject IWeightGoalService WeightGoalService
@inject IWeightService WeightService

<PageTitle>User Settings</PageTitle>

<h1>User Settings</h1>
<p>Update your profile and save your weight goal preferences.</p>

<p class="mb-4">
    <a class="btn btn-outline-primary btn-sm" href="/weight-goals">Open weight page</a>
</p>

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success">@SuccessMessage</div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(DeleteErrorMessage))
{
    <div class="alert alert-danger">@DeleteErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(goalErrorMessage))
{
    <div class="alert alert-danger">@goalErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(goalSuccessMessage))
{
    <div class="alert alert-success">@goalSuccessMessage</div>
}

<div class="row g-4 mb-4">
    <div class="col-12 col-xl-5">
        <div class="card h-100">
            <div class="card-header">Profile</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" value="@Email" readonly />
                </div>

                <form method="post" action="/auth/update-display-name">
                    <div class="mb-3">
                        <label class="form-label">Display Name</label>
                        <input class="form-control" name="DisplayName" value="@DisplayName" required />
                    </div>

                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card h-100">
            <div class="card-header">Save Weight Goal</div>
            <div class="card-body">
                <EditForm Model="goalModel" OnValidSubmit="SaveGoalAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Current weight (kg)</label>
                            <InputNumber class="form-control" @bind-Value="goalModel.CurrentWeightKg" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Goal weight (kg)</label>
                            <InputNumber class="form-control" @bind-Value="goalModel.GoalWeightKg" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Goal type</label>
                            <InputSelect class="form-select" @bind-Value="goalModel.GoalType">
                                <option value="@WeightGoalType.LoseWeight">Lose weight</option>
                                <option value="@WeightGoalType.GainWeight">Gain weight</option>
                                <option value="@WeightGoalType.MaintainWeight">Maintain weight</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Target pace</label>
                            <InputSelect class="form-select" @bind-Value="goalModel.PacePreference">
                                <option value="@GoalPacePreference.Aggressive">Aggressive</option>
                                <option value="@GoalPacePreference.Moderate">Moderate</option>
                                <option value="@GoalPacePreference.Slow">Slow</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Exercise frequency</label>
                            <InputSelect class="form-select" @bind-Value="goalModel.ExerciseFrequency">
                                <option value="@ExerciseFrequency.Sedentary">Sedentary / little to no exercise</option>
                                <option value="@ExerciseFrequency.Light">Light (1-2 times per week)</option>
                                <option value="@ExerciseFrequency.Moderate">Moderate (3-4 times per week)</option>
                                <option value="@ExerciseFrequency.Active">Active (5+ times per week)</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Exercise intensity</label>
                            <InputSelect class="form-select" @bind-Value="goalModel.ExerciseIntensity">
                                <option value="@ExerciseIntensity.Low">Low</option>
                                <option value="@ExerciseIntensity.Medium">Medium</option>
                                <option value="@ExerciseIntensity.High">High</option>
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Save Weight Goal</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

<div class="card border-danger">
    <div class="card-header text-danger">Danger Zone</div>
    <div class="card-body">
        <p class="mb-3">
            Deleting your account is permanent. Your related data will be removed with it.
        </p>

        <form method="post" action="/auth/delete-account">
            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input class="form-control" type="password" name="CurrentPassword" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Type DELETE to confirm</label>
                <input class="form-control" name="Confirmation" required />
            </div>

            <button type="submit" class="btn btn-danger">Delete Account</button>
        </form>
    </div>
</div>

@code {
    private sealed class WeightGoalFormModel
    {
        [Range(typeof(float), "0.1", "1000")]
        public float CurrentWeightKg { get; set; }

        [Range(typeof(float), "0.1", "1000")]
        public float GoalWeightKg { get; set; }

        public WeightGoalType GoalType { get; set; } = WeightGoalType.MaintainWeight;
        public GoalPacePreference PacePreference { get; set; } = GoalPacePreference.Moderate;
        public ExerciseFrequency ExerciseFrequency { get; set; } = ExerciseFrequency.Moderate;
        public ExerciseIntensity ExerciseIntensity { get; set; } = ExerciseIntensity.Medium;
    }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string Email = "";
    private string DisplayName = "";

    private string? SuccessMessage;
    private string? ErrorMessage;
    private string? DeleteErrorMessage;
    private string? goalSuccessMessage;
    private string? goalErrorMessage;

    private WeightGoalFormModel goalModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        Email = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
        DisplayName = user.Identity?.Name ?? "";

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("success", out var success))
            SuccessMessage = Uri.UnescapeDataString(success.ToString());

        if (query.TryGetValue("error", out var error))
            ErrorMessage = Uri.UnescapeDataString(error.ToString());

        if (query.TryGetValue("deleteError", out var deleteError))
            DeleteErrorMessage = Uri.UnescapeDataString(deleteError.ToString());

        await LoadGoalAsync();
    }

    private async Task SaveGoalAsync()
    {
        goalErrorMessage = null;
        goalSuccessMessage = null;

        var result = await WeightGoalService.SaveGoalAsync(new WeightGoalInput
        {
            CurrentWeightKg = goalModel.CurrentWeightKg,
            GoalWeightKg = goalModel.GoalWeightKg,
            GoalType = goalModel.GoalType,
            PacePreference = goalModel.PacePreference,
            ExerciseFrequency = goalModel.ExerciseFrequency,
            ExerciseIntensity = goalModel.ExerciseIntensity
        });

        if (!result.Success)
        {
            goalErrorMessage = result.Error;
            return;
        }

        goalSuccessMessage = "Weight goal saved.";
        await LoadGoalAsync();
    }

    private async Task LoadGoalAsync()
    {
        var goal = await WeightGoalService.GetGoalAsync();
        var latestWeight = await WeightService.GetLatestWeightKgAsync();

        goalModel.CurrentWeightKg = goal.CurrentWeightKg > 0 ? goal.CurrentWeightKg : latestWeight ?? 0;
        goalModel.GoalWeightKg = goal.GoalWeightKg > 0 ? goal.GoalWeightKg : latestWeight ?? 0;
        goalModel.GoalType = goal.GoalType;
        goalModel.PacePreference = goal.PacePreference;
        goalModel.ExerciseFrequency = goal.ExerciseFrequency;
        goalModel.ExerciseIntensity = goal.ExerciseIntensity;
    }
}
