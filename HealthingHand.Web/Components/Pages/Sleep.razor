@page "/sleep"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using HealthingHand.Web.Services
@using HealthingHand.Web.Services.SleepItems
@using Microsoft.AspNetCore.Authorization
@inject ISleepService SleepService

@attribute [Authorize]

<h3>Sleep</h3>

<p class="text-muted">Log your sleep and review your recent nights.</p>

<p class="mb-4">
    <a class="btn btn-outline-primary btn-sm" href="/sleep-goals">Manage sleep goals</a>
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success" role="alert">@message</div>
}

<div class="row g-4 mb-4">
    <div class="col-12 col-xl-5">
        <div class="card h-100">
            <div class="card-header">Add or Update Sleep Entry</div>
            <div class="card-body">
                <EditForm Model="model" OnValidSubmit="SaveSleepAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Sleep Date</label>
                            <InputDate class="form-control" @bind-Value="model.SleepDate" max="@TodayDateString" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Quality (0.0 - 5.0)</label>
                            <InputNumber @bind-Value="model.Quality"
                                         class="form-control"
                                         min="0"
                                         max="5"
                                         step="0.03125" />
                            <div class="form-text">Supports decimals. Stored internally as fixed-point (value × 32).</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Bed Time</label>
                            <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="model.BedTime" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Wake Time</label>
                            <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="model.WakeTime" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <InputTextArea class="form-control" @bind-Value="model.Notes" rows="3" />
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Save Sleep</button>
                        </div>
                    </div>
                </EditForm>

                <div class="alert alert-warning mt-3 mb-0" role="alert">
                    Entries under 4.5 hours are flagged as very low sleep so they stand out in your history.
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card h-100 sleep-chart-card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span>Sleep Hours Over Time</span>
                <span class="text-muted">Last 14 days</span>
            </div>
            <div class="card-body">
                @if (chartPoints.Count == 0)
                {
                    <p class="mb-0 text-muted">Add sleep entries to see your hours trend.</p>
                }
                else
                {
                    <div class="chart-summary-row">
                        <div>
                            <div class="chart-stat">@summary.AverageHours.ToString("0.0")h</div>
                            <div class="text-muted small">average over the last 30 days</div>
                        </div>
                        <div>
                            <div class="chart-stat">@chartPeakHours.ToString("0.0")h</div>
                            <div class="text-muted small">highest night in the chart</div>
                        </div>
                    </div>

                    <div class="sleep-chart-wrap">
                        <svg class="sleep-chart" viewBox="0 0 640 260" role="img" aria-label="Sleep hours by day">
                            <line x1="56" y1="220" x2="612" y2="220" class="chart-axis" />
                            <line x1="56" y1="24" x2="56" y2="220" class="chart-axis" />
                            <line x1="56" y1="24" x2="612" y2="24" class="chart-grid" />
                            <line x1="56" y1="122" x2="612" y2="122" class="chart-grid" />
                            <line x1="56" y1="220" x2="612" y2="220" class="chart-grid" />

                            <polyline points="@chartLinePoints" class="chart-line" />

                            @foreach (var point in chartPoints)
                            {
                                <circle cx="@point.X" cy="@point.Y" r="4" class="chart-dot" />
                            }
                        </svg>

                        @if (chartPoints.Count > 0)
                        {
                            var first = chartPoints.First();
                            var middle = chartPoints[chartPoints.Count / 2];
                            var last = chartPoints.Last();

                            <span class="chart-x-label" style="@GetChartLabelStyle(first.X)">@first.Label</span>
                            <span class="chart-x-label" style="@GetChartLabelStyle(middle.X)">@middle.Label</span>
                            <span class="chart-x-label" style="@GetChartLabelStyle(last.X)">@last.Label</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Recent Entries (Last 30 Days)</span>
        <span class="text-muted">Avg: @summary.AverageHours.ToString("0.0")h</span>
    </div>
    <div class="card-body p-0">
        @if (entries.Count == 0)
        {
            <p class="p-3 mb-0">No sleep entries yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped mb-0 align-middle">
                    <thead>
                    <tr>
                        <th>Date</th>
                        <th>Bed</th>
                        <th>Wake</th>
                        <th>Duration</th>
                        <th>Quality</th>
                        <th>Details</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var entry in entries)
                    {
                        var isExpanded = expandedEntryId == entry.Id;

                        <tr>
                            <td>@entry.SleepDate.ToString("MMM dd, yyyy")</td>
                            <td>@entry.StartTime.ToString("hh:mm tt")</td>
                            <td>@entry.EndTime.ToString("hh:mm tt")</td>
                            <td>
                                @FormatDuration(entry.DurationHours)
                                @if (IsExcessivelyLowSleep(entry.DurationHours))
                                {
                                    <span class="badge text-bg-warning ms-2">Low</span>
                                }
                            </td>
                            <td>@entry.SleepQuality.ToString("0.##")/5</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ToggleDetails(entry.Id)">
                                    @(isExpanded ? "Hide Details" : "View Details")
                                </button>
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntryAsync(entry.Id)">
                                    Delete
                                </button>
                            </td>
                        </tr>

                        @if (isExpanded)
                        {
                            <tr class="table-light">
                                <td colspan="7">
                                    <div class="p-3 sleep-detail-grid">
                                        <div><strong>Sleep Window:</strong> @entry.StartTime.ToString("MMM dd, yyyy hh:mm tt") to @entry.EndTime.ToString("MMM dd, yyyy hh:mm tt")</div>
                                        <div><strong>Total Duration:</strong> @FormatDuration(entry.DurationHours)</div>
                                        <div><strong>Sleep Quality:</strong> @entry.SleepQuality.ToString("0.##")/5</div>
                                        <div><strong>Notes:</strong> @(string.IsNullOrWhiteSpace(entry.Notes) ? "No notes added." : entry.Notes)</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .sleep-chart-card {
        overflow: hidden;
    }

    .chart-summary-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .chart-stat {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1;
    }

    .sleep-chart {
        width: 100%;
        height: auto;
        display: block;
    }

    .chart-axis {
        stroke: #748094;
        stroke-width: 1.5;
    }

    .chart-grid {
        stroke: #d9e1ec;
        stroke-width: 1;
        stroke-dasharray: 4 4;
    }

    .chart-line {
        fill: none;
        stroke: #1f6feb;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .chart-dot {
        fill: #1f6feb;
        stroke: white;
        stroke-width: 2;
    }

    .chart-label {
        fill: #5f6b7a;
        font-size: 12px;
    }

    .sleep-detail-grid {
        display: grid;
        gap: 0.5rem;
    }

    .sleep-chart-wrap {
        position: relative;
        width: 100%;
        padding-bottom: 2rem;
    }

    .chart-x-label {
        position: absolute;
        bottom: 0;
        transform: translateX(-50%);
        color: #5f6b7a;
        font-size: 12px;
        white-space: nowrap;
        line-height: 1;
    }
</style>

@code {
    private sealed class SleepFormModel
    {
        [Required]
        public DateOnly SleepDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        [Required]
        public TimeOnly BedTime { get; set; } = new(22, 30);

        [Required]
        public TimeOnly WakeTime { get; set; } = new(6, 30);

        [Range(0.0f, 5.0f)]
        public float Quality { get; set; } = 3.0f;

        [StringLength(500)]
        public string Notes { get; set; } = "";
    }

    private sealed record SleepChartPoint(string Label, double Hours, double X, double Y);

    private SleepFormModel model = new();
    private List<SleepListItem> entries = [];
    private List<SleepTrendPoint> trend = [];
    private List<SleepChartPoint> chartPoints = [];
    private SleepSummaryDto summary = new();

    private double chartMaxHours = 8;
    private double chartPeakHours;
    private int? expandedEntryId;
    private string chartLinePoints = "";
    private string? message;
    private string? errorMessage;
    private string TodayDateString => DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    protected override async Task OnInitializedAsync()
    {
        await LoadEntriesAsync();
    }

    private async Task SaveSleepAsync()
    {
        errorMessage = null;
        message = null;

        var start = model.SleepDate.ToDateTime(model.BedTime);
        var end = model.SleepDate.ToDateTime(model.WakeTime);

        if (end <= start)
        {
            end = end.AddDays(1);
        }

        var result = await SleepService.SaveAsync(new SleepEntryInput
        {
            StartTime = start,
            EndTime = end,
            SleepQuality = model.Quality,
            Notes = model.Notes
        });

        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        message = IsExcessivelyLowSleep((end - start).TotalHours)
            ? "Sleep entry saved. This duration is flagged as very low."
            : "Sleep entry saved.";
        model.Notes = "";
        await LoadEntriesAsync();
    }

    private async Task DeleteEntryAsync(int id)
    {
        errorMessage = null;
        message = null;

        var result = await SleepService.DeleteAsync(id);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        if (expandedEntryId == id) expandedEntryId = null;

        message = "Sleep entry deleted.";
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var from = today.AddDays(-29);

        entries = (await SleepService.ListHistoryAsync(from, today)).ToList();
        summary = await SleepService.GetSummaryAsync(from, today);
        trend = (await SleepService.GetTrendAsync(14)).ToList();

        BuildChart(today);
    }

    private void BuildChart(DateOnly today)
    {
        const int totalDays = 14;
        const double chartLeft = 56;
        const double chartTop = 24;
        const double chartWidth = 556;
        const double chartHeight = 196;

        var chartStart = today.AddDays(-(totalDays - 1));
        var hoursByDate = trend
            .Where(t => t.SleepDate >= chartStart && t.SleepDate <= today)
            .ToDictionary(t => t.SleepDate, t => Math.Max(0, t.DurationHours));

        var daySeries = Enumerable.Range(0, totalDays)
            .Select(offset => chartStart.AddDays(offset))
            .Select(date => new
            {
                Date = date,
                Hours = hoursByDate.TryGetValue(date, out var hours) ? hours : 0
            })
            .ToList();

        chartPeakHours = daySeries.Count == 0 ? 0 : daySeries.Max(d => d.Hours);
        chartMaxHours = Math.Max(8, Math.Ceiling(chartPeakHours + 1));

        const double xStep = chartWidth / (totalDays - 1);
        chartPoints = daySeries
            .Select((day, index) =>
            {
                var x = chartLeft + xStep * index;
                var normalized = chartMaxHours <= 0 ? 0 : day.Hours / chartMaxHours;
                var y = chartTop + chartHeight - (normalized * chartHeight);

                return new SleepChartPoint(
                    day.Date.ToString("MM/dd", CultureInfo.InvariantCulture),
                    day.Hours, x, y);
            })
            .ToList();

        chartLinePoints = string.Join(
            " ",
            chartPoints.Select(point =>
                $"{point.X.ToString("0.##", CultureInfo.InvariantCulture)},{point.Y.ToString("0.##", CultureInfo.InvariantCulture)}"));
    }

    private void ToggleDetails(int id) => expandedEntryId = expandedEntryId == id ? null : id;

    private static string FormatDuration(double hours)
    {
        var ts = TimeSpan.FromHours(hours);
        return ts.ToString(@"h\h\ mm\m");
    }
    
    private static string GetChartLabelStyle(double x)
    {
        var percent = (x / 640.0) * 100.0;
        return $"left: {percent.ToString("0.###", CultureInfo.InvariantCulture)}%;";
    }

    private static bool IsExcessivelyLowSleep(double hours)
    {
        // Anything below three full 90-minute cycles is highlighted for visibility.
        return hours < 4.5;
    }
}